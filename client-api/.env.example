# Service Desk API Configuration
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URL=mongodb+srv://sweetiDesk123:Sweeti%402004@cluster0.bjkzpzt.mongodb.net/serviceDeskDB?retryWrites=true&w=majority&appName=Cluster0

# JWT Secrets (generate random strings for production)
JWT_ACCESS_SECRET=your_access_token_secret_key_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_key_change_this_in_production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Redis (for token blacklisting)
REDIS_URL=redis://localhost:6379

# Email Configuration (Nodemailer)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password
EMAIL_SERVICE=gmail
EMAIL_FROM=noreply@resolvehub.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Admin Email (for notifications)
ADMIN_EMAIL=admin@resolvehub.com
